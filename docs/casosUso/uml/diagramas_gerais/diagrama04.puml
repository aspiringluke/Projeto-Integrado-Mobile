@startuml UC_Diagramacao
left to right direction
skinparam PackageStyle rectangle

actor "Usuário" as U

rectangle "Sistema de Escrita Criativa - Diagramação" {
    usecase "UC15: Criar diagrama de relacionamento de entidades" as UC15
    usecase "UC17: Gestão de grupos de nós em diagramas" as UC17
    usecase "UC19: Excluir nó e tratar arestas órfãs" as UC19
    usecase "UC20: Gestão de atributos detalhados no diagrama" as UC20
}

U --> UC15
U --> UC17
U --> UC19
U --> UC20

UC15 <.-. UC20: <<extends>>
@enduml
