@startuml Diagrama de Sequencia - Criacao de Personagem

title Diagrama de Sequencia - Criacao de Personagem (com Data Layer)

skinparam backgroundColor white
skinparam sequence {
    ArrowColor #5B4B54
    LifeLineBorderColor #8B7380
    LifeLineBackgroundColor #F8F2F5
    ParticipantBorderColor #8B7380
    ParticipantBackgroundColor #FDF7FA
    ActorBorderColor #6C5562
    ActorBackgroundColor #F4E8EE
}

actor "Usuario" as Usuario

participant "CharactersPage / CharacterForm\n<<View>>" as CharacterView
participant "CharacterController\n<<Controller>>" as CharacterCtrl
participant "Personagem\n<<Model>>" as Personagem
participant "Projeto\n<<Model>>" as Projeto
participant "CharacterRepository\n<<Repository>>" as CharacterRepository
participant "ProjectRepository\n<<Repository>>" as ProjectRepository
participant "db.dart / SQLite\n<<Database>>" as SQLiteDB

Usuario -> CharacterView: Abrir projeto e tocar no botao "+"
CharacterView -> CharacterView: Exibir formulario de personagem
Usuario -> CharacterView: Preencher dados e confirmar

CharacterView -> CharacterCtrl: submitNovoPersonagem(idProjeto, draft)
CharacterCtrl -> CharacterCtrl: validarCamposObrigatorios(draft)

alt Dados obrigatorios invalidos
    CharacterCtrl --> CharacterView: exibirErrosFormulario(campos)
    CharacterView --> Usuario: Solicitar correcao dos dados
else Dados obrigatorios validos
    opt Imagem informada
        CharacterCtrl -> CharacterCtrl: validarRegrasDeUpload(imagem)
    end

    CharacterCtrl -> Personagem: criarComDados(draft)
    Personagem --> CharacterCtrl: entidadePronta

    CharacterCtrl -> CharacterRepository: create(idProjeto, entidadePronta)
    CharacterRepository -> SQLiteDB: INSERT INTO Personagem(...)

    alt Persistencia do personagem com sucesso
        SQLiteDB --> CharacterRepository: sucesso
        CharacterRepository --> CharacterCtrl: sucesso

        CharacterCtrl --> CharacterView: atualizar()
        CharacterView --> Usuario: Exibir novo estado
    else Falha na persistencia
        SQLiteDB --> CharacterRepository: erroBanco
        CharacterRepository --> CharacterCtrl: falhaPersistencia(mensagem)
        CharacterCtrl --> CharacterView: exibirErroPersistencia(mensagem)
        CharacterView --> Usuario: Informar falha na criacao
    end
end

note over CharacterCtrl,SQLiteDB
Fluxo alinhado aos UCs de criacao/edicao de personagem
end note

@enduml
