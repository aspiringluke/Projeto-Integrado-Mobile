@startuml diagrama_UC12

|Usuário|
start
:Acessar chat de IA;
:Digitar pergunta;
:Clicar em "Enviar";

|Sistema|
if (Mensagem vazia?) then (sim)
  :Solicitar texto válido;
  stop
else (não)
  :Encaminhar mensagem para o serviço de IA;
endif

|Serviço de IA|
:Processar solicitação;

|Sistema|
if (Serviço disponível?) then (sim)
  :Exibir resposta no chat;
else (não)
  :Informar indisponibilidade temporária;
endif

stop
@enduml
