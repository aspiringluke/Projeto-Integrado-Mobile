@startuml diagrama_UC13

|Usuário|
start
:Acessar item que contém menu de adição de tag;
:Nomear novo grupo de tag;

|Sistema|
if (Nome do grupo vazio?) then (sim)
  :Rejeitar silenciosamente e não criar grupo;
  stop
else (não)
  if (Grupo já existente?) then (sim)
    :Manter grupo anterior, sem criar novo;
  else (não)
    |Usuário|
    :Selecionar cor do grupo;
    :Confirmar criação do grupo de tag;
    |Sistema|
    :Criar grupo de tag;
  endif
endif

|Usuário|
:Nomear uma tag dentro do grupo;

|Sistema|
if (Nome da tag vazio?) then (sim)
  :Rejeitar silenciosamente e não criar tag;
  stop
else (não)
  if (Tag já existente no grupo?) then (sim)
    :Manter tag anterior, sem criar nova;
  else (não)
    |Usuário|
    :Selecionar cor da tag;
    :Confirmar criação da tag;
    |Sistema|
    :Criar tag no grupo;
  endif
endif

stop
@enduml
