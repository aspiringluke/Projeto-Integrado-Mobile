@startuml diagrama_UC14

|Usuário|
start
:Acessar seção "Diagramas";
:Selecionar "Criar novo diagrama";

|Sistema|
:Inicializar plano de edição;

|Usuário|
:Inserir nós e conexões;
:Clicar em "Salvar";

|Sistema|
if (Estrutura mínima atendida?) then (sim)
  :Persistir diagrama;
  :Exibir confirmação;
else (não)
  :Exibir alerta de estrutura inválida;
endif

stop
@enduml
