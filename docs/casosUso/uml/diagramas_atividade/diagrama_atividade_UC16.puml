@startuml diagrama_UC16

|Usuário|
start
:Acessar "Configurações Gerais";
:Ativar "Modo Desempenho";

|Sistema|
:Aplicar perfil visual simplificado;

if (Configuração aplicada com sucesso?) then (sim)
  :Confirmar modo ativo;
else (não)
  :Manter configuração anterior e informar falha;
endif

|Usuário|
if (Deseja desativar?) then (sim)
  |Sistema|
  :Restaurar configuração visual padrão;
endif

stop
@enduml
