@startuml diagrama_UC21

|Usuário|
start
:Acessar menu de segurança;

if (Ação?) then (Alterar senha)
  |Sistema|
  :Solicitar senha atual;
  |Usuário|
  :Inserir senha atual;
  |Sistema|
  if (Senha atual correta?) then (sim)
    |Usuário|
    :Inserir e confirmar nova senha;
    |Sistema|
    if (Nova senha válida?) then (sim)
      :Salvar nova credencial;
    else (não)
      :Exibir regra de senha inválida;
    endif
  else (não)
    :Exibir erro de autenticação;
  endif
else (Remover senha)
  |Sistema|
  :Solicitar confirmação da identidade;
  |Usuário|
  :Confirmar identidade;
  |Sistema|
  if (Identidade confirmada?) then (sim)
    :Remover obrigatoriedade de senha;
  else (não)
    :Cancelar remoção de senha;
  endif
endif

stop
@enduml
